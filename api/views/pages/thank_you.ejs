<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
  <title>Thanks for reaching out!</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" type="text/css"/>
  <!--[if mso]>
  <style type="text/css">body,table,td,a{font-family:Arial,Helvetica,sans-serif!important;}</style>
  <![endif]-->
</head>
<body style="margin:0;padding:0;background-color:#f4f4f8;">
  <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="background-color:#f4f4f8;">
    <tr>
      <td align="center" style="padding:40px 16px;">
        <!-- Card -->
        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="600" style="max-width:600px;width:100%;border-radius:16px;overflow:hidden;border:1px solid #e5e7eb;">

          <!-- Header -->
          <tr>
            <td bgcolor="#0f0c29" align="center" style="background-color:#0f0c29;padding:52px 40px 44px;">
              <table role="presentation" border="0" cellpadding="0" cellspacing="0" style="margin:0 auto;">
                <tr>
                  <td width="52" height="52" bgcolor="#6366f1" align="center" valign="middle"
                      style="background-color:#6366f1;border-radius:12px;font-size:22px;font-weight:700;color:#ffffff;font-family:'DM Sans',Arial,sans-serif;line-height:52px;text-align:center;">N</td>
                </tr>
              </table>
              <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%">
                <tr><td height="20" style="font-size:20px;line-height:20px;">&nbsp;</td></tr>
              </table>
              <h1 style="font-size:26px;font-weight:600;color:#f8f8ff;margin:0 0 8px;letter-spacing:-0.5px;font-family:'DM Sans',Arial,sans-serif;">Thanks for reaching out!</h1>
              <p style="font-size:15px;color:#a5b4fc;margin:0;font-family:'DM Sans',Arial,sans-serif;">I'll be in touch soon</p>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td bgcolor="#ffffff" style="background-color:#ffffff;padding:32px 36px;">

              <!-- Badge -->
              <table role="presentation" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:24px;">
                <tr>
                  <td bgcolor="#ecfdf5" style="background-color:#ecfdf5;border-radius:20px;border:1px solid #6ee7b7;padding:5px 14px;">
                    <span style="color:#10b981;font-size:13px;font-weight:500;font-family:'DM Sans',Arial,sans-serif;">&#10003; Message received</span>
                  </td>
                </tr>
              </table>

              <!-- Greeting -->
              <p style="color:#111827;font-size:16px;font-weight:500;margin:0 0 12px;font-family:'DM Sans',Arial,sans-serif;">Hi <%= displayName.split(' ')[0] %>,</p>
              <p style="color:#6b7280;font-size:15px;line-height:1.7;margin:0 0 24px;font-family:'DM Sans',Arial,sans-serif;">Thank you for getting in touch &mdash; it truly means a lot. I've received your message and will get back to you as soon as possible. I'm looking forward to connecting with you.</p>

              <!-- CTA button -->
              <table role="presentation" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:28px;">
                <tr>
                  <td bgcolor="#4f46e5" style="background-color:#4f46e5;border-radius:10px;text-align:center;">
                    <a href="https://<%= locals.siteUrl || 'njmtech.co.za' %>"
                       style="display:block;padding:14px 32px;color:#ffffff;text-decoration:none;font-size:15px;font-weight:600;font-family:'DM Sans',Arial,sans-serif;white-space:nowrap;">
                      Visit NJMTech &rarr;
                    </a>
                  </td>
                </tr>
              </table>

              <!-- Contact info -->
              <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:24px;">
                <tr>
                  <td bgcolor="#f9fafb" style="background-color:#f9fafb;border-radius:10px;border:1px solid #f0f0f5;padding:16px 20px;">
                    <p style="color:#6b7280;font-size:14px;margin:0;font-family:'DM Sans',Arial,sans-serif;">Have more questions? Email me directly at <a href="mailto:<%= contactEmail %>" style="color:#6366f1;text-decoration:none;"><%= contactEmail %></a></p>
                  </td>
                </tr>
              </table>

              <!-- Divider -->
              <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:24px;">
                <tr><td style="border-top:1px solid #f0f0f5;font-size:0;line-height:0;">&nbsp;</td></tr>
              </table>

              <!-- Sign-off -->
              <p style="color:#6b7280;font-size:15px;line-height:1.7;margin:0;font-family:'DM Sans',Arial,sans-serif;">Warm regards,<br/>
                <strong style="color:#6366f1;font-size:16px;"><%= senderName %></strong>
              </p>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td bgcolor="#f9fafb" align="center" style="background-color:#f9fafb;padding:20px 36px;border-top:1px solid #f0f0f5;">
              <p style="color:#9ca3af;font-size:12px;margin:0;font-family:'DM Sans',Arial,sans-serif;">You're receiving this because you contacted via <a href="https://<%= locals.siteUrl || 'njmtech.co.za' %>" style="color:#9ca3af;text-decoration:underline;"><%= locals.siteUrl || 'njmtech.co.za' %></a></p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>