<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
  <title>New message from <%= displayName %></title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" type="text/css"/>
  <!--[if mso]>
  <style type="text/css">body,table,td,a{font-family:Arial,Helvetica,sans-serif!important;}</style>
  <![endif]-->
</head>
<body style="margin:0;padding:0;background-color:#0d0d0d;">
  <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="background-color:#0d0d0d;">
    <tr>
      <td align="center" style="padding:40px 16px;">
        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="600" style="max-width:600px;width:100%;border-radius:16px;overflow:hidden;border:1px solid #2a2522;background-color:#121212;">
          <tr>
            <td bgcolor="#121212" align="center" style="background-color:#121212;padding:52px 40px 44px;border-bottom:1px solid #2a2522;">
              <table role="presentation" border="0" cellpadding="0" cellspacing="0" style="margin:0 auto;">
                <tr>
                  <td width="52" height="52" bgcolor="#1a1a1a" align="center" valign="middle"
                      style="background-color:#1a1a1a;border-radius:12px;border:1px solid #8e2a2a;font-size:20px;font-weight:700;color:#f0e7df;font-family:'DM Sans',Arial,sans-serif;line-height:52px;text-align:center;">SG</td>
                </tr>
              </table>
              <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%">
                <tr><td height="20" style="font-size:20px;line-height:20px;">&nbsp;</td></tr>
              </table>
              <h1 style="font-size:26px;font-weight:600;color:#f0e7df;margin:0 0 8px;letter-spacing:-0.5px;font-family:'DM Sans',Arial,sans-serif;">New inquiry received</h1>
              <p style="font-size:15px;color:#b8aba0;margin:0;font-family:'DM Sans',Arial,sans-serif;">Someone reached out through Style &amp; Grace</p>
            </td>
          </tr>
          <tr>
            <td bgcolor="#121212" style="background-color:#121212;padding:32px 36px;">
              <table role="presentation" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:24px;">
                <tr>
                  <td bgcolor="#1a1414" style="background-color:#1a1414;border:1px solid #8e2a2a;border-radius:20px;padding:4px 12px;">
                    <span style="color:#b93636;font-size:11px;font-weight:600;letter-spacing:0.3px;text-transform:uppercase;font-family:'DM Sans',Arial,sans-serif;">Client Contact</span>
                  </td>
                </tr>
              </table>

              <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:20px;">
                <tr>
                  <td width="80" valign="top" style="padding:12px 0;border-bottom:1px solid #2a2522;color:#8b7f76;font-size:12px;text-transform:uppercase;letter-spacing:0.5px;font-weight:500;font-family:'DM Sans',Arial,sans-serif;">Name</td>
                  <td valign="top" style="padding:12px 0;border-bottom:1px solid #2a2522;color:#f0e7df;font-size:15px;font-weight:500;font-family:'DM Sans',Arial,sans-serif;"><%= displayName %></td>
                </tr>
                <tr>
                  <td width="80" valign="top" style="padding:12px 0;border-bottom:1px solid #2a2522;color:#8b7f76;font-size:12px;text-transform:uppercase;letter-spacing:0.5px;font-weight:500;font-family:'DM Sans',Arial,sans-serif;">Email</td>
                  <td valign="top" style="padding:12px 0;border-bottom:1px solid #2a2522;font-size:15px;font-family:'DM Sans',Arial,sans-serif;">
                    <a href="mailto:<%= email %>" style="color:#c54b4b;text-decoration:none;"><%= email %></a>
                  </td>
                </tr>
                <tr>
                  <td width="80" valign="top" style="padding:12px 0;border-bottom:1px solid #2a2522;color:#8b7f76;font-size:12px;text-transform:uppercase;letter-spacing:0.5px;font-weight:500;font-family:'DM Sans',Arial,sans-serif;">Subject</td>
                  <td valign="top" style="padding:12px 0;border-bottom:1px solid #2a2522;color:#f0e7df;font-size:15px;font-weight:500;font-family:'DM Sans',Arial,sans-serif;"><%= subject %></td>
                </tr>
              </table>

              <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:28px;">
                <tr>
                  <td bgcolor="#151515" style="background-color:#151515;border-radius:10px;border:1px solid #2a2522;padding:20px 24px;">
                    <p style="color:#c4b7ad;font-size:15px;line-height:1.7;margin:0;font-family:'DM Sans',Arial,sans-serif;white-space:pre-wrap;"><%= message %></p>
                  </td>
                </tr>
              </table>

              <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%">
                <tr>
                  <td align="center">
                    <table role="presentation" border="0" cellpadding="0" cellspacing="0">
                      <tr>
                        <td bgcolor="#8e2a2a" style="background-color:#8e2a2a;border-radius:10px;text-align:center;">
                          <a href="mailto:<%= email %>?subject=<%= encodeURIComponent('Re: ' + subject) %>"
                             style="display:block;padding:14px 32px;color:#f8f1eb;text-decoration:none;font-size:15px;font-weight:600;font-family:'DM Sans',Arial,sans-serif;white-space:nowrap;">
                            Reply to <%= displayName.split(' ')[0] %> &rarr;
                          </a>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td bgcolor="#121212" align="center" style="background-color:#121212;padding:20px 36px;border-top:1px solid #2a2522;">
              <p style="color:#8b7f76;font-size:12px;margin:0;font-family:'DM Sans',Arial,sans-serif;">Sent via the Style &amp; Grace contact form &middot; Hit Reply to respond directly</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
