<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
  <title>Thanks for shopping with Style &amp; Grace!</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" type="text/css"/>
  <!--[if mso]>
  <style type="text/css">body,table,td,a{font-family:Arial,Helvetica,sans-serif!important;}</style>
  <![endif]-->
</head>
<body style="margin:0;padding:0;background-color:#0d0d0d;">
  <%
    const orderItems = Array.isArray(locals.orderItems || locals.order_items) ? (locals.orderItems || locals.order_items) : [];
    const orderSummary = [
      ['Order number', locals.orderNumber || locals.order_number],
      ['Order date', locals.orderDate || locals.order_date],
      ['Payment status', locals.paymentStatus || locals.payment_status],
      ['Shipping method', locals.shippingMethod || locals.shipping_method],
      ['Estimated delivery', locals.estimatedDelivery || locals.estimated_delivery],
    ].filter(([, value]) => value);
    const totals = [
      ['Subtotal', locals.subtotal],
      ['Shipping', locals.shipping],
      ['Discount', locals.discount],
      ['Tax', locals.tax],
      ['Total', locals.total],
    ].filter(([, value]) => value);
  %>
  <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="background-color:#0d0d0d;">
    <tr>
      <td align="center" style="padding:40px 16px;">
        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="600" style="max-width:600px;width:100%;border-radius:16px;overflow:hidden;border:1px solid #2a2522;background-color:#121212;">
          <tr>
            <td bgcolor="#121212" align="center" style="background-color:#121212;padding:52px 40px 44px;border-bottom:1px solid #2a2522;">
              <table role="presentation" border="0" cellpadding="0" cellspacing="0" style="margin:0 auto;">
                <tr>
                  <td width="52" height="52" bgcolor="#1a1a1a" align="center" valign="middle"
                      style="background-color:#1a1a1a;border-radius:12px;border:1px solid #8e2a2a;font-size:20px;font-weight:700;color:#f0e7df;font-family:'DM Sans',Arial,sans-serif;line-height:52px;text-align:center;">SG</td>
                </tr>
              </table>
              <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%">
                <tr><td height="20" style="font-size:20px;line-height:20px;">&nbsp;</td></tr>
              </table>
              <h1 style="font-size:26px;font-weight:600;color:#f0e7df;margin:0 0 8px;letter-spacing:-0.5px;font-family:'DM Sans',Arial,sans-serif;">Thanks for your order!</h1>
              <p style="font-size:15px;color:#b8aba0;margin:0;font-family:'DM Sans',Arial,sans-serif;">Your Style &amp; Grace purchase is being prepared</p>
            </td>
          </tr>
          <tr>
            <td bgcolor="#121212" style="background-color:#121212;padding:32px 36px;">
              <table role="presentation" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:24px;">
                <tr>
                  <td bgcolor="#1a1414" style="background-color:#1a1414;border-radius:20px;border:1px solid #8e2a2a;padding:5px 14px;">
                    <span style="color:#b93636;font-size:13px;font-weight:500;font-family:'DM Sans',Arial,sans-serif;">&#10003; Order confirmed</span>
                  </td>
                </tr>
              </table>

              <p style="color:#f0e7df;font-size:16px;font-weight:500;margin:0 0 12px;font-family:'DM Sans',Arial,sans-serif;">Hi <%= displayName.split(' ')[0] %>,</p>
              <p style="color:#c4b7ad;font-size:15px;line-height:1.7;margin:0 0 16px;font-family:'DM Sans',Arial,sans-serif;">Thank you for shopping with Style &amp; Grace. We're getting your order ready and will be in touch as soon as it's on the way.</p>
              <p style="color:#c4b7ad;font-size:15px;line-height:1.7;margin:0 0 24px;font-family:'DM Sans',Arial,sans-serif;">We appreciate you choosing us for pieces that bring effortless style to your everyday wardrobe.</p>

              <% if (orderSummary.length > 0) { %>
                <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:24px;border:1px solid #2a2522;border-radius:14px;">
                  <tr>
                    <td bgcolor="#181414" style="background-color:#181414;padding:20px 22px;">
                      <p style="color:#f0e7df;font-size:16px;font-weight:600;margin:0 0 14px;font-family:'DM Sans',Arial,sans-serif;">Order summary</p>
                      <% orderSummary.forEach(([label, value]) => { %>
                        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:10px;">
                          <tr>
                            <td style="color:#8b7f76;font-size:13px;font-family:'DM Sans',Arial,sans-serif;"><%= label %></td>
                            <td align="right" style="color:#f0e7df;font-size:13px;font-weight:600;font-family:'DM Sans',Arial,sans-serif;"><%= value %></td>
                          </tr>
                        </table>
                      <% }) %>
                    </td>
                  </tr>
                </table>
              <% } %>

              <% if (orderItems.length > 0) { %>
                <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:24px;border:1px solid #2a2522;border-radius:14px;">
                  <tr>
                    <td bgcolor="#151515" style="background-color:#151515;padding:20px 22px;">
                      <p style="color:#f0e7df;font-size:16px;font-weight:600;margin:0 0 16px;font-family:'DM Sans',Arial,sans-serif;">Items in your order</p>
                      <% orderItems.forEach((item, index) => { %>
                        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="<%= index < orderItems.length - 1 ? 'margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid #2a2522;' : '' %>">
                          <tr>
                            <% if (item.image_url) { %>
                              <td valign="top" width="76" style="padding-right:14px;">
                                <img src="<%= item.image_url %>" alt="<%= item.name || 'Product image' %>" width="76" style="display:block;width:76px;height:76px;border-radius:10px;object-fit:cover;border:1px solid #2a2522;"/>
                              </td>
                            <% } %>
                            <td valign="top">
                              <p style="color:#f0e7df;font-size:15px;font-weight:600;margin:0 0 6px;font-family:'DM Sans',Arial,sans-serif;"><%= item.name || 'Item' %></p>
                              <% if (item.variant) { %><p style="color:#8b7f76;font-size:13px;margin:0 0 4px;font-family:'DM Sans',Arial,sans-serif;"><%= item.variant %></p><% } %>
                              <p style="color:#8b7f76;font-size:13px;margin:0;font-family:'DM Sans',Arial,sans-serif;">Qty: <%= item.quantity ?? 1 %></p>
                            </td>
                            <td valign="top" align="right" style="color:#f0e7df;font-size:14px;font-weight:600;font-family:'DM Sans',Arial,sans-serif;white-space:nowrap;">
                              <%= item.subtotal || item.price || item.unit_price || '' %>
                            </td>
                          </tr>
                        </table>
                      <% }) %>
                    </td>
                  </tr>
                </table>
              <% } %>

              <% if (totals.length > 0) { %>
                <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:24px;border:1px solid #2a2522;border-radius:14px;">
                  <tr>
                    <td bgcolor="#181414" style="background-color:#181414;padding:20px 22px;">
                      <p style="color:#f0e7df;font-size:16px;font-weight:600;margin:0 0 14px;font-family:'DM Sans',Arial,sans-serif;">Payment breakdown</p>
                      <% totals.forEach(([label, value]) => { %>
                        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:10px;">
                          <tr>
                            <td style="color:<%= label === 'Total' ? '#f0e7df' : '#8b7f76' %>;font-size:13px;<%= label === 'Total' ? 'font-weight:600;' : '' %>font-family:'DM Sans',Arial,sans-serif;"><%= label %></td>
                            <td align="right" style="color:#f0e7df;font-size:<%= label === 'Total' ? '15px' : '13px' %>;font-weight:600;font-family:'DM Sans',Arial,sans-serif;"><%= value %></td>
                          </tr>
                        </table>
                      <% }) %>
                    </td>
                  </tr>
                </table>
              <% } %>

              <% if (locals.shippingAddress || locals.shipping_address || locals.billingAddress || locals.billing_address) { %>
                <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:24px;">
                  <tr>
                    <% if (locals.shippingAddress || locals.shipping_address) { %>
                      <td valign="top" width="50%" style="padding-right:8px;">
                        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="border:1px solid #2a2522;border-radius:14px;">
                          <tr>
                            <td bgcolor="#151515" style="background-color:#151515;padding:18px 20px;">
                              <p style="color:#f0e7df;font-size:15px;font-weight:600;margin:0 0 10px;font-family:'DM Sans',Arial,sans-serif;">Shipping address</p>
                              <p style="color:#8b7f76;font-size:13px;line-height:1.6;white-space:pre-line;margin:0;font-family:'DM Sans',Arial,sans-serif;"><%= locals.shippingAddress || locals.shipping_address %></p>
                            </td>
                          </tr>
                        </table>
                      </td>
                    <% } %>
                    <% if (locals.billingAddress || locals.billing_address) { %>
                      <td valign="top" width="50%" style="padding-left:8px;">
                        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="border:1px solid #2a2522;border-radius:14px;">
                          <tr>
                            <td bgcolor="#151515" style="background-color:#151515;padding:18px 20px;">
                              <p style="color:#f0e7df;font-size:15px;font-weight:600;margin:0 0 10px;font-family:'DM Sans',Arial,sans-serif;">Billing address</p>
                              <p style="color:#8b7f76;font-size:13px;line-height:1.6;white-space:pre-line;margin:0;font-family:'DM Sans',Arial,sans-serif;"><%= locals.billingAddress || locals.billing_address %></p>
                            </td>
                          </tr>
                        </table>
                      </td>
                    <% } %>
                  </tr>
                </table>
              <% } %>

              <table role="presentation" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:28px;">
                <tr>
                  <td bgcolor="#8e2a2a" style="background-color:#8e2a2a;border-radius:10px;text-align:center;">
                    <a href="<%= locals.siteUrl || '#' %>"
                       style="display:block;padding:14px 32px;color:#f8f1eb;text-decoration:none;font-size:15px;font-weight:600;font-family:'DM Sans',Arial,sans-serif;white-space:nowrap;">
                      Continue shopping &rarr;
                    </a>
                  </td>
                </tr>
              </table>

              <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:24px;">
                <tr>
                  <td bgcolor="#151515" style="background-color:#151515;border-radius:10px;border:1px solid #2a2522;padding:16px 20px;">
                    <p style="color:#c4b7ad;font-size:14px;margin:0;font-family:'DM Sans',Arial,sans-serif;">Need help with your order? Email us at <a href="mailto:<%= contactEmail %>" style="color:#c54b4b;text-decoration:none;"><%= contactEmail %></a></p>
                  </td>
                </tr>
              </table>

              <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:24px;">
                <tr><td style="border-top:1px solid #2a2522;font-size:0;line-height:0;">&nbsp;</td></tr>
              </table>

              <p style="color:#c4b7ad;font-size:15px;line-height:1.7;margin:0;font-family:'DM Sans',Arial,sans-serif;">Warm regards,<br/>
                <strong style="color:#c54b4b;font-size:16px;"><%= senderName %></strong>
              </p>
            </td>
          </tr>
          <tr>
            <td bgcolor="#121212" align="center" style="background-color:#121212;padding:20px 36px;border-top:1px solid #2a2522;">
              <p style="color:#8b7f76;font-size:12px;margin:0;font-family:'DM Sans',Arial,sans-serif;">You're receiving this because you placed an order with <a href="<%= locals.siteUrl || '#' %>" style="color:#8b7f76;text-decoration:underline;"><%= locals.siteUrl || 'Style &amp; Grace' %></a></p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
