<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: "Inter", Arial, sans-serif;
      background: #f8f7ff;
      color: #1e1b4b;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── Header ── */
    header {
      background: #1e1b4b;
      padding: 18px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
    }

    .logo-mark {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
    }

    .logo-badge {
      background: #4f46e5;
      color: #fff;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 1px;
      padding: 5px 10px;
      border-radius: 6px;
    }

    .logo-name {
      color: #e0e7ff;
      font-size: 15px;
      font-weight: 600;
    }

    .header-link {
      color: #a5b4fc;
      font-size: 13px;
      text-decoration: none;
      border: 1px solid #4f46e5;
      border-radius: 6px;
      padding: 6px 14px;
      transition: background 0.2s, color 0.2s;
    }

    .header-link:hover { background: #4f46e5; color: #fff; }

    /* ── Sub-header ── */
    .sub-header {
      background: #312e81;
      padding: 14px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
      flex-shrink: 0;
    }

    .sub-header-title {
      color: #e0e7ff;
      font-size: 14px;
      font-weight: 500;
    }

    .sub-header-title span {
      color: #a5b4fc;
      font-size: 12px;
      margin-left: 8px;
    }

    /* ── Tab bar ── */
    .tab-bar {
      background: #fff;
      border-bottom: 2px solid #e0e7ff;
      padding: 0 32px;
      display: flex;
      gap: 0;
      overflow-x: auto;
      flex-shrink: 0;
    }

    .tab {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 20px;
      font-size: 13px;
      font-weight: 500;
      color: #6b7280;
      cursor: pointer;
      border-bottom: 2px solid transparent;
      margin-bottom: -2px;
      white-space: nowrap;
      transition: color 0.15s, border-color 0.15s;
      user-select: none;
    }

    .tab:hover { color: #4f46e5; }

    .tab.active {
      color: #4f46e5;
      border-bottom-color: #4f46e5;
      font-weight: 600;
    }

    .tab-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #c7d2fe;
      flex-shrink: 0;
    }

    .tab.active .tab-dot { background: #4f46e5; }

    /* ── Preview area ── */
    .preview-wrapper {
      flex: 1;
      display: flex;
      flex-direction: column;
      min-height: 0;
    }

    .preview-panel {
      display: none;
      flex: 1;
      flex-direction: column;
      min-height: 0;
    }

    .preview-panel.active { display: flex; }

    .preview-toolbar {
      background: #f1f5f9;
      border-bottom: 1px solid #e0e7ff;
      padding: 10px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 12px;
      color: #6b7280;
      flex-shrink: 0;
    }

    .preview-toolbar code {
      background: #e0e7ff;
      color: #4338ca;
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 11px;
    }

    .toolbar-actions { display: flex; gap: 8px; }

    .toolbar-btn {
      font-size: 12px;
      font-weight: 500;
      color: #4f46e5;
      text-decoration: none;
      border: 1px solid #c7d2fe;
      border-radius: 5px;
      padding: 4px 10px;
      background: #fff;
      cursor: pointer;
      transition: background 0.15s;
    }

    .toolbar-btn:hover { background: #ede9fe; }

    .iframe-container {
      flex: 1;
      background: #e5e7eb;
      padding: 24px;
      overflow: auto;
      display: flex;
      justify-content: center;
      align-items: flex-start;
    }

    .iframe-shell {
      background: #fff;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 4px 24px rgba(0,0,0,0.10);
      width: 100%;
      max-width: 680px;
      min-height: 600px;
      display: flex;
      flex-direction: column;
    }

    .iframe-chrome {
      background: #f8fafc;
      border-bottom: 1px solid #e2e8f0;
      padding: 10px 14px;
      display: flex;
      align-items: center;
      gap: 6px;
      flex-shrink: 0;
    }

    .chrome-dot { width: 10px; height: 10px; border-radius: 50%; }
    .chrome-dot.red   { background: #fc635d; }
    .chrome-dot.amber { background: #fdbc40; }
    .chrome-dot.green { background: #34c749; }

    .chrome-bar {
      flex: 1;
      background: #e2e8f0;
      border-radius: 4px;
      padding: 4px 10px;
      font-size: 11px;
      color: #94a3b8;
      margin-left: 8px;
    }

    iframe {
      flex: 1;
      width: 100%;
      border: none;
      min-height: 580px;
    }

    /* ── Footer ── */
    footer {
      background: #1e1b4b;
      color: #a5b4fc;
      text-align: center;
      padding: 14px 32px;
      font-size: 12px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    footer a { color: #a5b4fc; text-decoration: none; }
    footer a:hover { color: #e0e7ff; }
    .footer-socials { display: flex; gap: 10px; }
    .footer-socials a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 30px;
      height: 30px;
      border-radius: 50%;
      border: 1px solid rgba(165,180,252,0.3);
      color: #a5b4fc;
      transition: background 0.2s, color 0.2s, border-color 0.2s;
    }
    .footer-socials a:hover { background: #4f46e5; border-color: #4f46e5; color: #fff; }
    .footer-socials svg { width: 13px; height: 13px; fill: currentColor; }
  </style>
</head>
<body>

  <header>
    <a class="logo-mark" href="/">
      <span class="logo-badge">NJM</span>
      <span class="logo-name">Email Template API</span>
    </a>
    <a class="header-link" href="/" >← Back to Home</a>
  </header>

  <div class="sub-header">
    <span class="sub-header-title">
      Template Preview
      <span>Rendered with sample data — click a tab to switch</span>
    </span>
  </div>

  <nav class="tab-bar" role="tablist">
    <button class="tab active" role="tab" data-target="contact_notification">
      <span class="tab-dot"></span>Contact Notification
    </button>
    <button class="tab" role="tab" data-target="contact_confirmation">
      <span class="tab-dot"></span>Contact Confirmation
    </button>
    <button class="tab" role="tab" data-target="subscribe_welcome">
      <span class="tab-dot"></span>Subscribe Welcome
    </button>
    <button class="tab" role="tab" data-target="thank_you">
      <span class="tab-dot"></span>Thank You
    </button>
  </nav>

  <div class="preview-wrapper">

    <% const templates = [
      { id: 'contact_notification',  label: 'contact_notification' },
      { id: 'contact_confirmation',  label: 'contact_confirmation' },
      { id: 'subscribe_welcome',     label: 'subscribe_welcome'    },
      { id: 'thank_you',             label: 'thank_you'            },
    ]; %>

    <% templates.forEach(function(t, i) { %>
    <div class="preview-panel <%= i === 0 ? 'active' : '' %>" id="panel-<%= t.id %>">
      <div class="preview-toolbar">
        <span>GET <code>/preview/<%= t.id %></code></span>
        <div class="toolbar-actions">
          <a class="toolbar-btn" href="/preview/<%= t.id %>" target="_blank" rel="noopener">Open in new tab ↗</a>
        </div>
      </div>
      <div class="iframe-container">
        <div class="iframe-shell">
          <div class="iframe-chrome">
            <span class="chrome-dot red"></span>
            <span class="chrome-dot amber"></span>
            <span class="chrome-dot green"></span>
            <span class="chrome-bar">/preview/<%= t.id %></span>
          </div>
          <iframe
            id="iframe-<%= t.id %>"
            title="<%= t.label %> preview"
            loading="lazy"
          ></iframe>
        </div>
      </div>
    </div>
    <% }); %>

  </div>

  <footer>
    <div class="footer-socials">
      <a href="https://www.linkedin.com/in/njmalaza" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
        <svg viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
      <a href="https://twitter.com/nhlanhlamalaza_" target="_blank" rel="noopener noreferrer" aria-label="Twitter / X">
        <svg viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/></svg>
      </a>
      <a href="https://github.com/omoinjm" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
        <svg viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
      </a>
    </div>
    <p>NJMTech Email Template API &mdash; <a href="/">Home</a></p>
  </footer>

  <script>
    const tabs = document.querySelectorAll('.tab');
    const panels = document.querySelectorAll('.preview-panel');
    const loaded = new Set();

    function loadIframe(templateId) {
      if (loaded.has(templateId)) return;
      loaded.add(templateId);
      const iframe = document.getElementById('iframe-' + templateId);
      if (iframe) iframe.src = '/preview/' + templateId;
    }

    // Load first tab immediately
    loadIframe('contact_notification');

    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        const target = tab.dataset.target;

        tabs.forEach(function(t) { t.classList.remove('active'); });
        panels.forEach(function(p) { p.classList.remove('active'); });

        tab.classList.add('active');
        const panel = document.getElementById('panel-' + target);
        if (panel) panel.classList.add('active');

        loadIframe(target);
      });
    });
  </script>

</body>
</html>
